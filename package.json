  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0",
    "typescript": "^5.9.3",
    "@tanstack/react-router": "^1.168.1"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
