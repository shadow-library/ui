{
  "name": "@shadow-library/ui",
  "version": "0.1.3",
  "type": "module",
  "description": "Shadow UI — enterprise React component library for the Shadow Apps ecosystem, styled with CSS Modules and CSS-variable design tokens, documented in Storybook, with full TypeScript support",
  "scripts": {
    "build": "bun scripts/build.ts",
    "storybook": "storybook dev -p 4000",
    "build-storybook": "storybook build",
    "type-check": "tsc",
    "test:setup": "bunx playwright install",
    "test": "vitest run --project unit",
    "test:stories": "vitest run --project storybook",
    "lint": "biome check",
    "format": "biome format --write",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/shadow-library/ui.git"
  },
  "author": "Leander Paul <leanderpaul97@outlook.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/shadow-library/ui/issues"
  },
  "homepage": "https://github.com/shadow-library/ui#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@release-it/conventional-changelog": "^10.0.6",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-onboarding": "^10.4.6",
    "@storybook/addon-themes": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@tanstack/react-router": "^1.168.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "happy-dom": "^20.8.4",
    "husky": "^9.1.7",
    "lightningcss": "^1.32.0",
    "playwright": "^1.58.2",
    "postcss-import": "^16.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "release-it": "^19.2.4",
